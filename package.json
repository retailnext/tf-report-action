{
  "name": "tf-report-action",
  "version": "1.0.0",
  "description": "Reports OpenTofu/Terraform workflow status as PR comments or status issues with rich plan/apply detail",
  "license": "MIT",
  "author": "RetailNext",
  "keywords": [
    "github-action",
    "opentofu",
    "terraform"
  ],
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "typecheck": "tsc --noEmit -p tsconfig.test.json",
    "lint": "npm run lint:es && npm run lint:markdown && npm run lint:text && npm run format:check",
    "lint:es": "eslint src tests",
    "lint:markdown": "markdownlint-cli2 '**/*.md' '#node_modules'",
    "lint:text": "textlint '*.md' '.github/**/*.md'",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "bundle": "npm run format && rm -rf dist && node scripts/esbuild.mjs",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:coverage:ci": "vitest run --coverage --reporter=verbose",
    "test:integration:coverage": "vitest run --config vitest.integration.config.ts --coverage",
    "render": "tsx scripts/render.ts",
    "gallery": "tsx scripts/render.ts --gallery",
    "check:dist": "npm run bundle && git diff --quiet dist/ || (echo 'dist/ is out of date. Run npm run bundle and commit the result.' && exit 1)",
    "ci": "npm run lint && npm run typecheck && npm run test:coverage:ci && npm run test:integration:coverage"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.0",
    "@types/node": "^24.12.4",
    "@vitest/coverage-v8": "^4.1.5",
    "esbuild": "^0.28.1",
    "eslint": "^10.0.0",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-boundaries": "^6.0.2",
    "eslint-plugin-import-x": "^4.0.0",
    "eslint-plugin-no-barrel-files": "^1.3.1",
    "markdownlint-cli2": "^0.22.0",
    "prettier": "^3.8.3",
    "textlint": "^15.7.1",
    "textlint-filter-rule-comments": "^1.3.0",
    "textlint-rule-terminology": "^5.2.16",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.59.1",
    "vitest": "^4.0.0"
  },
  "overrides": {
    "glob": "^13.0.6",
    "js-yaml": "^4.2.0",
    "markdown-it": "^14.2.0"
  }
}
